# Preserved source archives are binary blobs — keep them out of regular git
# history via Git LFS. Integrity is also recorded as SHA256 in each entry's
# README "Source Code" section (generated by scripts/archive.py).
*.tar.gz   filter=lfs diff=lfs merge=lfs -text
*.tar.bz2  filter=lfs diff=lfs merge=lfs -text
*.tgz      filter=lfs diff=lfs merge=lfs -text
*.gz       filter=lfs diff=lfs merge=lfs -text
*.bz2      filter=lfs diff=lfs merge=lfs -text
*.zip      filter=lfs diff=lfs merge=lfs -text
